# OPTIONS_MOVER_TOP_N=14
# OPTIONS_MOVER_MIN_ABS_PCT=1.5
# OPTIONS_MOVER_UNIVERSE_EXTRA=SPY,QQQ,IWM,AMD,COIN,HOOD,ORCL,PLTR,NFLX,BA,GS,JPM
