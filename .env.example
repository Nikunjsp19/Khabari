# Copy to .env and fill in real values. Never commit .env.

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/Khabari?retryWrites=true&w=majority
MONGODB_DB=Khabari

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- Python API ---
PYTHON_API_PORT=8000
WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,AMD,AVGO,JPM,BAC,GS,NFLX,TSM,HOOD,PLTR,NOW,MSTR,COIN,SMCI,ARM,RDDT
WATCHLIST_AUTO_FAMOUS=true
INITIAL_CASH=1000

# --- Market data APIs ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKETAUX_API_TOKEN=
NEWSDATA_API_KEY=

# --- Options (separate paper book; Yahoo/yfinance — no API key) ---
# Delayed chains + IV; delta estimated with Black-Scholes.
OPTIONS_WATCHLIST=TSLA,NVDA,AAPL,MSFT,AMZN
OPTIONS_INITIAL_CASH=1000
# OPTIONS_AUTO_MOVERS=true
# OPTIONS_MOVER_TOP_N=14
# OPTIONS_MOVER_MIN_ABS_PCT=1.5
# OPTIONS_MOVER_UNIVERSE_EXTRA=SPY,QQQ,IWM,AMD,COIN,HOOD,ORCL,PLTR,NFLX,BA,GS,JPM
# OPTIONS_MIN_NOTIFY_CONFIDENCE=65
# OPTIONS_MAX_PREMIUM_PCT=0.40
# OPTIONS_MIN_CASH_PCT=0.05
# OPTIONS_MIN_DTE=7
# OPTIONS_MAX_DTE=45
# OPTIONS_SCHEDULER_ENABLED=true
# OPTIONS_BACKUP_ANALYZE_HOURS=1
# OPTIONS_TAKE_PROFIT_PCT=40
# OPTIONS_STOP_LOSS_PCT=35

# --- LLM (Gemini default; OpenAI optional) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-flash-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notifications (easiest: ntfy) ---
NTFY_TOPIC=your-secret-topic-name
NTFY_SERVER=https://ntfy.sh

# --- Free-tier guards (keep Gemini quota safe) ---
# NEWS_SCAN_MINUTES=30
# POSITION_MONITOR_MINUTES=60
# ANALYZE_COOLDOWN_MINUTES=45
# BACKUP_ANALYZE_HOURS=2
# MAX_ANALYZES_PER_DAY=16
# MAX_LLM_CALLS_PER_DAY=0
# MAX_DAILY_SPEND_USD=1
# MAX_MONTHLY_SPEND_USD=25
# QUOTA_PAUSE_MINUTES=90
# NEWS_MIN_NEW_ARTICLES=2
# MIN_NOTIFY_CONFIDENCE=58
# NOTIFY_ONLY_ACTIONABLE=true
# POSITION_TAKE_PROFIT_PCT=0     # 0 = no fixed target; winners ride the ATR trailing stop
# POSITION_STOP_LOSS_PCT=3.5     # only used when daily ATR is unavailable
# ANALYZE_PERIOD=5d
# ANALYZE_INTERVAL=15m
# DAY_WRAP_ENABLED=true
# DAY_WRAP_HOUR=16
# DAY_WRAP_MINUTE=15
# MAX_POSITION_PCT=0.40
# MIN_CASH_PCT=0.05

# --- Deterministic quant signal engine (pre-screens BUY candidates for the LLM) ---
# SIGNAL_BUY_THRESHOLD=60          # 0-100 score to be flagged BUY by the quant engine
# SIGNAL_CANDIDATE_MIN_SCORE=55    # min score to reach the LLM short-list
# SIGNAL_SHORTLIST_SIZE=6          # candidates handed to the LLM per run (held names extra)
# SIGNAL_SKIP_LLM_WHEN_NO_CANDIDATES=true  # save spend on quiet days
# --- Market regime filter (SPY vs 200d SMA + VIX) ---
# REGIME_VIX_CAUTION=20            # >= this VIX → neutral (trim size)
# REGIME_VIX_RISK_OFF=30          # >= this VIX (or SPY below 200d) → risk-off
# REGIME_BLOCK_BUYS_IN_RISK_OFF=true  # block new longs when risk-off
# --- Deterministic exit engine (ATR trailing / initial / time stops) ---
# EXIT_ENGINE_ENABLED=true
# EXIT_INITIAL_STOP_ATR_MULT=2.0  # initial hard stop = entry - N*ATR(14d)
# EXIT_TRAIL_ATR_MULT=3.0         # Chandelier trailing stop = high_water - N*ATR(14d)
# EXIT_TIME_STOP_DAYS=0           # sell stagnant trades after N days (0=off)
# EXIT_TIME_STOP_MIN_PROFIT_PCT=1.0
# EXIT_ALERT_COOLDOWN_MINUTES=60
