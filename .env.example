# --- LLM (Gemini default; OpenAI optional) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notifications (easiest: ntfy) ---
NTFY_TOPIC=your-secret-topic-name
NTFY_SERVER=https://ntfy.sh

