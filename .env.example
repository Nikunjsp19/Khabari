# Copy to .env and fill in real values. Never commit .env.

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/Khabari?retryWrites=true&w=majority
MONGODB_DB=Khabari

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- Python API ---
PYTHON_API_PORT=8000
WATCHLIST=TSLA,NVDA,AAPL,MSFT,AMZN
INITIAL_CASH=1000

# --- Market data APIs ---
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKETAUX_API_TOKEN=
NEWSDATA_API_KEY=

# --- LLM (Gemini default; OpenAI optional) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notifications (easiest: ntfy) ---
NTFY_TOPIC=your-secret-topic-name
NTFY_SERVER=https://ntfy.sh

# --- Free-tier guards (keep Gemini quota safe) ---
# NEWS_SCAN_MINUTES=30
# POSITION_MONITOR_MINUTES=60
# ANALYZE_COOLDOWN_MINUTES=45
# BACKUP_ANALYZE_HOURS=2
# MAX_ANALYZES_PER_DAY=8
# MAX_LLM_CALLS_PER_DAY=30
# MAX_MONTHLY_SPEND_USD=10
# QUOTA_PAUSE_MINUTES=90
# NEWS_MIN_NEW_ARTICLES=2
# MIN_NOTIFY_CONFIDENCE=70
# NOTIFY_ONLY_ACTIONABLE=true
# POSITION_TAKE_PROFIT_PCT=4
# POSITION_STOP_LOSS_PCT=3
# ANALYZE_PERIOD=5d
# ANALYZE_INTERVAL=15m
